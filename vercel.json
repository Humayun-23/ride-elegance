{
  "redirects": [
    { "source": "/rent/car-hire/in/:city", "destination": "/rent/car/in/:city", "statusCode": 301 },
    { "source": "/rent/rental-cars/in/:city", "destination": "/rent/car/in/:city", "statusCode": 301 },
    { "source": "/rent/self-drive-car/in/:city", "destination": "/rent/car/in/:city", "statusCode": 301 },
    { "source": "/rent/self-drive-cars/in/:city", "destination": "/rent/car/in/:city", "statusCode": 301 },
    { "source": "/rent/car-rent/in/:city", "destination": "/rent/car/in/:city", "statusCode": 301 },
    { "source": "/submit-email", "destination": "/", "statusCode": 301 }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/rent/(.*)",
      "destination": "/api/seo"
    },
    {
      "source": "/search/(.*)",
      "destination": "/api/seo"
    },
    {
      "source": "/(.*)",
      "destination": "/api/seo"
    }
  ]
}
